{
  "extends": "athom/homey-app",
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "rules": {
    "camelcase": "off",
    "import/extensions": "off",
    "import/no-unresolved": "off",
    "node/no-missing-import": "off",
    "node/no-unsupported-features/es-syntax": "off",
    "no-use-before-define": "off"
  }
}
